{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts,js,json --exec \"npx tsx\" src/server.ts",
